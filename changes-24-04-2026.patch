+        {error && <div className="err-bar">{error}</div>}
+
+        {loading ? (
+          <div style={{ textAlign: 'center', padding: '48px', color: '#9a9a9a' }}>Loading…</div>
+        ) : (
+          <div className="card">
+            {admins.length === 0 ? (
+              <div className="empty">No org admins found.</div>
+            ) : (
+              <table className="table">
