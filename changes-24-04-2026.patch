+            Create Super Admin
+          </button>
+        </div>
+
+        {error && <div className="err-bar">{error}</div>}
+
+        {loading ? (
+          <div style={{ textAlign: 'center', padding: '48px', color: '#9a9a9a' }}>Loading…</div>
