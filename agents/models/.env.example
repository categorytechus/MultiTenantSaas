# Copy this file to .env and fill values you need.
# Keep .env private.

# =========================
# Global LLM Selection
# =========================
# Used by load_llm(...)
LLM_PROVIDER=bedrock
LLM_TEMPERATURE=0

# =========================
# AWS Bedrock
# =========================
BEDROCK_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Use one option below:
# 1) Bedrock model name
BEDROCK_MODEL_NAME=
# 2) Bedrock model ARN + provider
BEDROCK_MODEL_ARN=
BEDROCK_MODEL_PROVIDER=

# =========================
# OpenAI
# =========================
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4-turbo

# =========================
# Gemini
# =========================
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash

# =========================
# Chat settings
# =========================
# Used by test_models.py
TEMPERATURE=0.7
MAX_TOKENS=500
