# Copy this file to .env and fill in your values
# cp .env.example .env

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/multitenant

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────
# Auth
# ──────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ──────────────────────────────────────────────
# AI / LLM config
# Set CHAT_MODEL to route between providers: bedrock, gemini, or openai.
# Set EMBEDDING_MODEL to the fastembed Hugging Face model you wish to use.
# ──────────────────────────────────────────────
CHAT_MODEL=bedrock
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
BEDROCK_MODEL_ARN=
BEDROCK_MODEL_PROVIDER=anthropic
AWS_BEDROCK_REGION=us-east-1
GEMINI_API_KEY=
OPENAI_API_KEY=

# ──────────────────────────────────────────────
# S3 (leave empty to use local filesystem in dev)
# ──────────────────────────────────────────────
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ──────────────────────────────────────────────
# Google OAuth (optional)
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ──────────────────────────────────────────────
# Agents service (src/agents only)
# URL of the server for internal API calls
# ──────────────────────────────────────────────
SERVER_URL=http://localhost:8000

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOCAL_UPLOAD_DIR=/tmp/uploads
